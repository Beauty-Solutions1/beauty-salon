    <script>
        // Set dynamic year in footer
        document.getElementById('year').textContent = new Date().getFullYear();
        
        // DYNAMIC URL DETECTION: This makes the link "actual" based on wherever the file is hosted
        window.onload = function() {
            const currentUrl = window.location.href.split('#')[0]; // Gets the base URL
            document.getElementById('booking-url').innerText = currentUrl;
        };

        // Navigation Scroll Effect
        const navbar = document.getElementById('navbar');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 100) {
                navbar.classList.add('bg-darkBg/95', 'h-16');
            } else {
                navbar.classList.remove('bg-darkBg/95', 'h-16');
            }
        });

        // Copy Booking Link Function
        function copyBookingLink() {
            const urlText = document.getElementById('booking-url').innerText;
            
            // Standard cross-browser copy approach
            const tempInput = document.createElement('input');
            tempInput.value = urlText;
            document.body.appendChild(tempInput);
            tempInput.select();
            document.execCommand('copy');
            document.body.removeChild(tempInput);
            
            showToast("Link Copied!", "You can now paste and send this to anyone via WhatsApp or text.");
            
            const btn = document.getElementById('copy-btn');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-check"></i> Link Copied!';
            setTimeout(() => { btn.innerHTML = originalText; }, 3000);
        }

        // Sharing Functions
        function shareVia(platform) {
            const url = document.getElementById('booking-url').innerText;
            const text = "Check out Beauty Solutions Salon at Courtyard Marriott! Book your session here:";
            let shareUrl = '';

            switch(platform) {
                case 'whatsapp':
                    shareUrl = `https://wa.me/?text=${encodeURIComponent(text + " " + url)}`;
                    break;
                case 'facebook':
                    shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;
                    break;
                case 'email':
                    shareUrl = `mailto:?subject=Beauty Solutions Salon Booking&body=${encodeURIComponent(text + " " + url)}`;
                    break;
            }
            if(shareUrl) window.open(shareUrl, '_blank');
        }

        // Toast Helper
        function showToast(title, body) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-title').innerText = title;
            document.getElementById('toast-body').innerText = body;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 4000);
        }

        // Form Submission
        const form = document.getElementById('bookingForm');
        form.addEventListener('submit', (e) => {
            e.preventDefault();
            const name = document.getElementById('clientName').value;
            showToast("Sent!", `Thanks ${name}! We will call you soon to confirm your appointment.`);
            form.reset();
        });

        // Mobile Menu Toggle
        const menuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        menuBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });
    </script>
</body>
</html>