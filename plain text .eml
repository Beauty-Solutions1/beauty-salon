    <!-- Success Toast -->
    <div id="toast" class="fixed bottom-10 right-10 bg-primary text-white p-8 rounded-3xl shadow-3xl z-50 flex items-start gap-6 max-w-sm border border-white/10 backdrop-blur-xl">
        <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center text-primary shrink-0">
